# Handle line endings automatically for all text files
* text=auto eol=lf

# Ensure source code files are always normalized to LF in the repository
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.mjs  text eol=lf
*.gs   text eol=lf
.env*  text eol=lf

# Binary files — never convert
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.woff binary
*.woff2 binary
